<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { pageTitle }) %>
  <body>
    <main class="page-shell">
      <%- include("partials/nav") %>
      <%- include("partials/flash", { flash }) %>

      <section class="panel library-panel" data-reveal>
        <div class="library-topbar">
          <div>
            <p class="eyebrow">Library</p>
            <h1>Your uploaded files</h1>
            <p class="lede-small">Search by name, then open or download the file you need.</p>
          </div>

          <form class="search-form" action="/files" method="GET">
            <label class="search-shell">
              <span class="search-icon" aria-hidden="true">Search</span>
              <input
                aria-label="Search files"
                type="search"
                name="q"
                value="<%= search %>"
                placeholder="Search by file name"
              />
            </label>
            <button class="button button-muted" type="submit">Search</button>
            <% if (search) { %>
              <a class="text-link" href="/files">Clear</a>
            <% } %>
          </form>
        </div>

        <% if (storageError) { %>
          <div class="flash flash-error"><%= storageError %></div>
        <% } %>

        <% if (!storageError && !files.length && search) { %>
          <section class="empty-state" data-reveal>
            <h2>No matching files</h2>
            <p>Try a different search term or clear the filter.</p>
            <a class="text-link" href="/files">Clear search</a>
          </section>
        <% } %>

        <% if (!storageError && !files.length && !search) { %>
          <section class="empty-state" data-reveal>
            <h2>No files yet</h2>
            <p>Upload your first file and it will appear here.</p>
            <a class="button" href="/">Upload a file</a>
          </section>
        <% } %>

        <% if (files.length) { %>
          <div class="library-meta">
            <span><%= files.length %> <%= files.length === 1 ? "file" : "files" %> shown</span>
            <span><%= search ? `Filter: ${search}` : "All files" %></span>
            <% if (hasMore) { %>
              <span>Showing the latest items first</span>
            <% } %>
          </div>

          <section class="file-list">
            <% files.forEach((file) => { %>
              <article class="file-card" data-reveal>
                <div class="file-kind"><%= file.kind %></div>
                <div class="file-main">
                  <h2 title="<%= file.displayName %>"><%= file.displayName %></h2>
                  <p class="file-meta">
                    <span><%= formatDate(file.uploadedAt) %></span>
                    <span>•</span>
                    <span><%= formatBytes(file.size) %></span>
                  </p>
                </div>
                <div class="file-actions">
                  <a class="button button-muted" href="/files/<%= file.id %>/open" target="_blank" rel="noreferrer">
                    Open
                  </a>
                  <a class="button" href="/files/<%= file.id %>/download">Download</a>
                </div>
              </article>
            <% }) %>
          </section>
        <% } %>
      </section>
    </main>
  </body>
</html>
