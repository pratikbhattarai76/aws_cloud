<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <main class="container">
    <h1>Uploaded Files</h1>
    <div class="links">
      <a href="/">Back to upload</a>
    </div>

    <% if (flash && flash.success) { %>
      <div class="message success"><%= flash.success %></div>
    <% } %>

    <% if (flash && flash.error) { %>
      <div class="message error"><%= flash.error %></div>
    <% } %>

    <% if (storageError) { %>
      <div class="message error"><%= storageError %></div>
    <% } %>

    <% if (!files.length) { %>
      <div class="card">
        <p>No files uploaded yet.</p>
      </div>
    <% } else { %>
      <div class="card">
        <table>
          <thead>
            <tr>
              <th>File</th>
              <th>Size</th>
              <th>Uploaded</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% files.forEach(file => { %>
              <tr>
                <td><%= file.displayName %></td>
                <td><%= formatBytes(file.size) %></td>
                <td><%= formatDate(file.uploadedAt) %></td>
                <td>
                  <a href="/files/<%= encodeURIComponent(file.id) %>/open">Open</a>
                  |
                  <a href="/files/<%= encodeURIComponent(file.id) %>/download">Download</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</body>
</html>
