<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>
  <body>
    <main class="page-shell">
      <%- include("partials/nav") %>
      <%- include("partials/flash", { flash }) %>

      <% const totalSize = files.reduce((sum, file) => sum + file.size, 0); %>
      <% const uploadHref = currentFolder ? `/?folder=${encodeURIComponent(currentFolder)}` : "/"; %>

      <section class="page-intro" data-reveal>
        <div>
          <p class="page-kicker">Library</p>
          <h1><%= currentFolder ? currentFolder.split("/").slice(-1)[0] : "Your Memories" %></h1>
          <p class="page-summary"><%= currentFolder || "Browse folders and files in one place." %></p>
        </div>
        <div class="page-intro-actions">
          <a class="button button-secondary" href="<%= uploadHref %>">Upload here</a>
          <% if (currentFolder) { %>
            <a
              class="button button-ghost"
              href="/folders/download?folder=<%= encodeURIComponent(currentFolder) %>&returnFolder=<%= encodeURIComponent(currentFolder) %>"
            >Download folder</a>
          <% } %>
        </div>
      </section>

      <% if (storageError) { %>
        <section class="notice <%= storageDisabled ? '' : 'notice-error' %>" data-reveal>
          <div>
            <p class="page-kicker"><%= storageDisabled ? "Local mode" : "Storage notice" %></p>
            <p class="notice-text"><%= storageError %></p>
          </div>
        </section>
      <% } %>

      <section class="panel library-toolbar" data-reveal>
        <section class="inline-folder-panel folder-popover library-folder-panel" id="library-folder-panel" data-library-folder-panel hidden>
          <form class="inline-folder-form" action="/folders" method="POST">
            <input type="hidden" name="parentFolder" value="<%= currentFolder %>" />
            <label class="sr-only" for="libraryFolderNames">Folder names</label>
            <textarea
              id="libraryFolderNames"
              name="folderNames"
              class="text-input folder-textarea"
              placeholder="Folder name or nested path"
              required
            ></textarea>
            <% if (storageDisabled) { %>
              <p class="preview-meta">This machine can show the UI, but folder creation only works when storage is available.</p>
            <% } %>
            <div class="inline-folder-actions">
              <button class="button button-ghost" type="button" data-panel-close>Cancel</button>
              <button class="button button-primary" type="submit" <%= storageDisabled ? "disabled" : "" %>>Create folder</button>
            </div>
          </form>
        </section>

        <div class="toolbar-top">
          <div class="breadcrumbs">
            <a class="path-chip path-chip-link" href="/files">Root</a>
            <% if (parentFolder) { %>
              <a class="path-chip path-chip-link" href="/files?folder=<%= encodeURIComponent(parentFolder) %>">Back</a>
            <% } %>
            <% if (currentFolder) { %>
              <span class="path-chip path-chip-current"><%= currentFolder %></span>
            <% } %>
          </div>

          <button
            class="button button-ghost button-small"
            type="button"
            data-library-folder-toggle
            aria-expanded="false"
            aria-controls="library-folder-panel"
          >Create folder</button>
        </div>

        <form class="search-form" action="/files" method="GET" role="search">
          <label class="sr-only" for="q">Search files</label>
          <% if (currentFolder) { %>
            <input type="hidden" name="folder" value="<%= currentFolder %>" />
          <% } %>
          <input id="q" name="q" type="search" class="text-input" value="<%= search %>" placeholder="Search this view" />
          <% if (search) { %>
            <a class="button button-ghost" href="<%= currentFolder ? `/files?folder=${encodeURIComponent(currentFolder)}` : '/files' %>">Clear</a>
          <% } %>
          <button class="button button-primary" type="submit">Search</button>
        </form>

        <p class="toolbar-summary">
          <%= folders.length %> folders · <%= files.length %> files · <%= formatBytes(totalSize) %> shown
        </p>
      </section>

      <% if (!folders.length && !files.length) { %>
        <section class="panel empty-state" data-reveal>
          <h1><%= search ? "No files match that search." : "This folder is empty." %></h1>
          <p>
            <%= search ? `Try another filename or clear the filter.` : "Create a folder or upload files here." %>
          </p>
          <div class="empty-actions">
            <% if (search) { %>
              <a class="button button-secondary" href="<%= currentFolder ? `/files?folder=${encodeURIComponent(currentFolder)}` : '/files' %>">Clear search</a>
            <% } %>
            <a class="button button-primary" href="<%= uploadHref %>">Upload files</a>
          </div>
        </section>
      <% } %>

      <% if (folders.length) { %>
        <section class="panel listing-section" data-reveal>
          <div class="section-heading">
            <div>
              <h2>Folders</h2>
            </div>
          </div>

          <div class="file-list" role="list">
            <% folders.forEach(folder => { %>
              <article class="file-row" role="listitem">
                <div class="file-row-main">
                  <span class="file-kind" aria-label="Folder">Folder</span>

                  <div class="file-copy">
                    <h2 class="file-name"><%= folder.name %></h2>
                    <p class="file-meta">
                      <span><%= folder.path %></span>
                    </p>
                  </div>
                </div>

                <div class="file-actions">
                  <a class="button button-secondary" href="/files?folder=<%= encodeURIComponent(folder.path) %>">Open folder</a>
                  <a
                    class="button button-ghost"
                    href="/folders/download?folder=<%= encodeURIComponent(folder.path) %><%= currentFolder ? `&returnFolder=${encodeURIComponent(currentFolder)}` : "" %>"
                  >Download</a>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (files.length) { %>
        <section class="panel listing-section" data-reveal>
          <div class="section-heading">
            <div>
              <h2><%= search ? `Results for "${search}"` : "Files" %></h2>
            </div>
            <div class="section-actions">
              <a class="button button-secondary" href="<%= uploadHref %>">Upload here</a>
            </div>
          </div>

          <div class="file-list" role="list">
            <% files.forEach(file => { %>
              <article class="file-row" role="listitem">
                <div class="file-row-main">
                  <span class="file-kind" aria-label="File type"><%= file.kind %></span>

                  <div class="file-copy">
                    <h2 class="file-name"><%= file.displayName %></h2>
                    <p class="file-meta">
                      <span><%= formatBytes(file.size) %></span>
                      <span><%= formatDate(file.uploadedAt) %></span>
                    </p>
                  </div>
                </div>

                <div class="file-actions">
                  <a class="button button-secondary" href="/files/<%= encodeURIComponent(file.id) %>/open">Open</a>
                  <a class="button button-ghost" href="/files/<%= encodeURIComponent(file.id) %>/download">Download</a>
                </div>
              </article>
            <% }) %>
          </div>

          <% if (hasMore) { %>
            <p class="library-note">Only the first storage batch is shown right now.</p>
          <% } %>
        </section>
      <% } %>
    </main>
  </body>
</html>
