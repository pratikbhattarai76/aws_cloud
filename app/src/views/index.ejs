<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { pageTitle }) %>
  <body>
    <main class="page-shell">
      <%- include("partials/nav") %>
      <%- include("partials/flash", { flash }) %>

      <section class="hero-grid">
        <section class="panel hero-copy" data-reveal>
          <h1>Upload files.</h1>
          <p class="lead">
            Choose files or a folder from your device, then upload them into the folder you want.
          </p>
          <p class="supporting-text">
            Upload up to <strong><%= maxFileCount %></strong> files at once. Each file can be up to
            <strong><%= maxFileSize %></strong>.
          </p>
        </section>

        <section class="panel" data-reveal>
          <div class="panel-header">
            <h2>Choose files or drop them here</h2>
          </div>

          <form action="/upload" method="POST" enctype="multipart/form-data" class="upload-form" data-upload-form>
            <input class="sr-only" type="file" name="files" id="files" data-file-input multiple required />
            <input class="sr-only" type="file" id="folders" data-folder-input webkitdirectory directory multiple />

            <div class="upload-config-row">
              <div class="field-group">
                <label class="field-label" for="uploadMode">Upload type</label>
                <select class="text-input" id="uploadMode" data-picker-mode>
                  <option value="files">Files</option>
                  <option value="folder">Folder from device</option>
                </select>
              </div>

              <div class="field-group">
                <div class="field-label-row">
                  <label class="field-label" for="folder">Upload into</label>
                  <button
                    class="button button-ghost button-small"
                    type="button"
                    data-upload-folder-toggle
                    aria-expanded="false"
                    aria-controls="upload-folder-panel"
                  >+ New folder</button>
                </div>

                <select class="text-input" id="folder" name="folder">
                  <option value="">Root</option>
                  <% folderOptions.forEach(folderOption => { %>
                    <option value="<%= folderOption %>" <%= currentFolder === folderOption ? "selected" : "" %>>
                      <%= folderOption %>
                    </option>
                  <% }) %>
                </select>
              </div>
            </div>

            <label class="dropzone" for="files" data-dropzone tabindex="0" aria-describedby="file-help">
              <span class="dropzone-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 16V4"></path>
                  <path d="m7 9 5-5 5 5"></path>
                  <path d="M5 20h14"></path>
                </svg>
              </span>
              <span class="dropzone-copy">
                <strong data-dropzone-title>Browse files from this device</strong>
                <span id="file-help" data-dropzone-help>You can also drag and drop multiple files into this area.</span>
              </span>
              <span class="file-label" data-file-label>No file selected</span>
            </label>

            <section class="file-preview" aria-live="polite">
              <p class="preview-title">Selected files</p>
              <div class="selected-files" data-selected-files>
                <p class="preview-meta">No file selected.</p>
              </div>
            </section>

            <div class="form-actions">
              <button class="button button-ghost" type="button" data-clear-button disabled>Clear files</button>
              <button class="button button-primary" type="submit" data-submit-button>Upload to S3</button>
              <a
                class="button button-secondary"
                href="<%= currentFolder ? `/files?folder=${encodeURIComponent(currentFolder)}` : '/files' %>"
              >Open library</a>
            </div>
          </form>

          <section class="inline-folder-panel" id="upload-folder-panel" data-upload-folder-panel hidden>
            <div class="inline-folder-panel-head">
              <div>
                <p class="preview-title">Create folder</p>
                <p class="preview-meta">Add one folder per line. Use `/` for nested folders.</p>
              </div>
            </div>

            <form class="inline-folder-form" action="/folders" method="POST">
              <input type="hidden" name="parentFolder" value="<%= currentFolder || '' %>" data-upload-folder-parent />
              <input type="hidden" name="redirectTo" value="upload" />
              <label class="sr-only" for="uploadFolderNames">Folder names</label>
              <textarea
                id="uploadFolderNames"
                name="folderNames"
                class="text-input folder-textarea"
                required
              ></textarea>
              <div class="inline-folder-actions">
                <button class="button button-primary" type="submit">Create folder</button>
              </div>
            </form>
          </section>
        </section>
      </section>
    </main>
  </body>
</html>
