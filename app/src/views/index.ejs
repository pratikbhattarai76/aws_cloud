<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <main class="container">
    <h1>AWS File Upload Portal</h1>
    <p>Upload files to Amazon S3 through your EC2-hosted app.</p>

    <% if (flash && flash.success) { %>
      <div class="message success"><%= flash.success %></div>
    <% } %>

    <% if (flash && flash.error) { %>
      <div class="message error"><%= flash.error %></div>
    <% } %>

    <form action="/upload" method="POST" enctype="multipart/form-data" class="card">
      <label for="file">Choose file</label>
      <input type="file" name="file" id="file" required />
      <button type="submit">Upload</button>
    </form>

    <div class="links">
      <a href="/files">View uploaded files</a>
    </div>
  </main>
</body>
</html>
