<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>
  <body>
    <% const libraryHref = currentFolder ? `/files?folder=${encodeURIComponent(currentFolder)}` : "/files"; %>
    <main class="page-shell">
      <%- include("partials/nav") %>
      <%- include("partials/flash", { flash }) %>

      <% if (storageNotice) { %>
        <section class="notice" data-reveal>
          <div>
            <p class="page-kicker">Local mode</p>
            <p class="notice-text"><%= storageNotice %></p>
          </div>
        </section>
      <% } %>

      <section class="page-intro" data-reveal>
        <div>
          <p class="page-kicker">Upload</p>
          <h1>Store Your Timeless Memories</h1>
          <p class="page-summary">
            Choose files or a folder, pick where they should go, and upload.
          </p>
        </div>
      </section>

      <section class="panel workspace-card" data-reveal>
        <section class="inline-folder-panel folder-popover" id="upload-folder-panel" data-upload-folder-panel hidden>
          <form class="inline-folder-form" action="/folders" method="POST">
            <input type="hidden" name="parentFolder" value="<%= currentFolder || '' %>" data-upload-folder-parent />
            <input type="hidden" name="redirectTo" value="upload" />
            <label class="sr-only" for="uploadFolderNames">Folder names</label>
            <textarea
              id="uploadFolderNames"
              name="folderNames"
              class="text-input folder-textarea"
              placeholder="Folder name or nested path"
              required
            ></textarea>
            <% if (storageNotice) { %>
              <p class="preview-meta">This machine can show the UI, but folder creation only works when storage is available.</p>
            <% } %>
            <div class="inline-folder-actions">
              <button class="button button-ghost" type="button" data-panel-close>Cancel</button>
              <button class="button button-primary" type="submit" <%= storageNotice ? "disabled" : "" %>>Create folder</button>
            </div>
          </form>
        </section>

        <form
          action="/upload"
          method="POST"
          enctype="multipart/form-data"
          class="upload-form"
          data-upload-form
          data-upload-max-bytes="<%= uploadMaxFileSizeBytes %>"
        >
          <input class="sr-only" type="file" name="files" id="files" data-file-input multiple required />
          <input class="sr-only" type="file" id="folders" data-folder-input webkitdirectory directory multiple />

          <div class="upload-config-row">
            <div class="field-group">
              <label class="field-label" for="uploadMode">Upload type</label>
              <select class="text-input" id="uploadMode" data-picker-mode>
                <option value="files">Files</option>
                <option value="folder">Folder from device</option>
              </select>
            </div>

            <div class="field-group">
              <div class="field-label-row">
                <label class="field-label" for="folder">Destination</label>
                <button
                  class="button button-ghost button-small"
                  type="button"
                  data-upload-folder-toggle
                  aria-expanded="false"
                  aria-controls="upload-folder-panel"
                >Create folder</button>
              </div>

              <select class="text-input" id="folder" name="folder">
                <option value="">Root</option>
                <% folderOptions.forEach(folderOption => { %>
                  <option value="<%= folderOption %>" <%= currentFolder === folderOption ? "selected" : "" %>>
                    <%= folderOption %>
                  </option>
                <% }) %>
              </select>
            </div>
          </div>

          <label class="dropzone" for="files" data-dropzone tabindex="0" aria-describedby="file-help">
            <span class="dropzone-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 16V4"></path>
                <path d="m7 9 5-5 5 5"></path>
                <path d="M5 20h14"></path>
              </svg>
            </span>
            <span class="dropzone-copy">
              <strong data-dropzone-title>Select files from your device</strong>
              <span id="file-help" data-dropzone-help>Or drag them into this area.</span>
            </span>
            <span class="file-label" data-file-label>No file selected</span>
          </label>

          <div class="workspace-columns">
            <section class="file-preview" aria-live="polite">
              <p class="preview-title">Selected files</p>
              <p class="preview-meta" data-selected-summary hidden></p>
              <div class="selected-files" data-selected-files>
                <p class="preview-meta">No file selected.</p>
              </div>
            </section>

            <section class="upload-progress" data-upload-progress aria-live="polite" hidden>
              <div class="upload-progress-head">
                <p class="preview-title">Upload progress</p>
                <p class="upload-progress-percent" data-upload-progress-percent>0%</p>
              </div>
              <progress class="upload-progress-bar" data-upload-progress-bar max="100" value="0">0%</progress>
              <p class="preview-name" data-upload-progress-status>Ready to upload.</p>
              <p class="preview-meta" data-upload-progress-meta>Select files to begin.</p>
            </section>
          </div>

          <div class="sr-only" data-selected-file-inputs aria-hidden="true"></div>

          <div class="form-actions upload-form-actions">
            <a class="button button-secondary" href="<%= libraryHref %>">Open library</a>
            <button class="button button-ghost" type="button" data-clear-button disabled>Clear files</button>
            <button class="button button-primary" type="submit" data-submit-button>Upload</button>
          </div>
        </form>
      </section>
    </main>
  </body>
</html>
